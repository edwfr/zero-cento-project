# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database (Prisma)
# Pooled connection via PgBouncer (port 6543) for app runtime
DATABASE_URL=postgresql://user:pass@db.supabase.co:6543/postgres?pgbouncer=true
# Direct connection (port 5432) for migrations - no PgBouncer
DIRECT_URL=postgresql://user:pass@db.supabase.co:5432/postgres

# Upstash Redis (rate limiting auth endpoints)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=xxx
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Resend (email transazionali: onboarding, reset password)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@zerocento.app

# App Configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
